# AWS DynamoDB with Vulnerability Assessment - Terraform Variables

#----------------------------------------
# General Configuration
#----------------------------------------
aws_region  = "us-east-1"
# Removed aws_profile to use default credentials

tags = {
  Environment = "Demo"
  Owner       = "Security"
  Project     = "Guardium-Terraform"
}

#----------------------------------------
# Guardium Data Source Registration Configuration
#----------------------------------------
dynamodb_datasource_name = "aws-dynamodb-va-example"
dynamodb_description     = "AWS DynamoDB with Vulnerability Assessment"
application              = "Security Assessment"
severity_level           = "MED"

#----------------------------------------
# Vulnerability Assessment Configuration
#----------------------------------------
enable_vulnerability_assessment = true

#----------------------------------------
# Guardium Connection Details
#----------------------------------------
gdp_server        = "guardium.example.com"  # Replace with your Guardium server
gdp_port          = 8443
guardium_username = "admin"                 # Replace with your Guardium username
guardium_password = "password"              # Replace with your Guardium password
client_id         = "client1"               # Replace with your client ID
client_secret     = "client-secret"         # Replace with your client secret

#----------------------------------------
# AWS Secrets Manager Configuration
#----------------------------------------
aws_secrets_manager_name = "guardium-aws"        # Name of the AWS Secrets Manager configuration in Guardium UI
aws_secrets_manager_region = "us-east-1"         # AWS region where the secret is stored
aws_secrets_manager_secret = "dynamodb-credentials"  # Name of the secret in AWS Secrets Manager

#----------------------------------------
# SSL/TLS Configuration (ENABLED BY DEFAULT FOR SECURITY)
#----------------------------------------
use_ssl = true                    # Enables SSL/TLS for Guardium connections (DEFAULT: true)
import_server_ssl_cert = true     # Imports AWS certificate automatically (DEFAULT: true)

#----------------------------------------
# Debug Configuration
#----------------------------------------
debug_mode = true  # Set to true for troubleshooting